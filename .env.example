# ── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=3000
# Gere com: openssl rand -base64 64
SESSION_SECRET=sua-chave-secreta-muito-longa-e-aleatoria-aqui
BASE_URL=http://localhost:3000
NODE_ENV=development

# Senha opcional para bloquear o app (se vazio, libera)
APP_PASSWORD=

# ── INTELIGÊNCIA ARTIFICIAL ───────────────────────────────────────────────────
# OpenAI (opcional, recomendado para humanização)
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj_...
OPENAI_MODEL=gpt-4o-mini

# Groq (principal — llama-3.3-70b-versatile)
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Google Gemini (secundário — gemini-2.5-flash)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# NVIDIA (fallback de alta performance)
# Obtenha em: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi_...

# == BANCO DE DADOS ==
# MongoDB Atlas para persistência (opcional)
# Configure em: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://...

# ── INSTAGRAM GRAPH API ───────────────────────────────────────────────────────
# IMPORTANTE: Gere User Access Tokens de longa duração no Meta for Developers
# Instruções:
# 1. Acesse https://developers.facebook.com/
# 2. Crie um app ou use um existente
# 3. Vá para "Configurações" > "Básico" e copie o ID do App
# 4. Vá para "Ferramentas" > "Graph API Explorer"
# 5. Selecione seu app e gere um User Access Token
# 6. Autorize as permissões: instagram_business_content_publish, instagram_basic
# 7. Converta para Long-Lived Token (válido por 60 dias)
# 8. Coloque o token aqui
#
# Para múltiplos clientes, separe os tokens por vírgula:
# IG_TOKENS=token_cliente_1,token_cliente_2,token_cliente_3
#
# O app carregará automaticamente os clientes na inicialização
IG_TOKENS=seu_token_aqui

# ── FACEBOOK LOGIN ────────────────────────────────────────────────────────────
# ID do App Meta para autenticação via Facebook Login
# Obtenha em: https://developers.facebook.com/ > Seu App > Configurações > Básico
FACEBOOK_APP_ID=seu_app_id_aqui
FACEBOOK_APP_SECRET=sua_app_secret_aqui

# URL de redirecionamento após login (deve estar configurada no Meta for Developers)
FACEBOOK_REDIRECT_URI=http://localhost:3000/auth/facebook/callback
