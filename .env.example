# =========================================================
#          EXEMPLO DE VARIÁVEIS DE AMBIENTE
# =========================================================
#
# Renomeie este arquivo para .env e preencha com seus valores.
# NUNCA suba o arquivo .env para o GitHub.

# --- Configuração do App Meta for Developers ---
# NOTA: O app atual usa login rápido com IG_TOKENS.
# Se quiser usar OAuth completo, crie seu app em https://developers.facebook.com/apps/
FB_APP_ID=
FB_APP_SECRET=

# --- Segurança da Sessão ---
# Use uma string longa e aleatória para máxima segurança.
SESSION_SECRET=seu-segredo-de-sessao-super-longo-e-aleatorio

# --- Inteligência Artificial (Google Gemini 2.5 Flash) ---
# Recomendado: Melhor qualidade e contexto maior. Obtenha em https://aistudio.google.com/
GEMINI_API_KEY=sua-chave-api-do-gemini-aqui

# --- Orçamento Máximo de Tokens (Gemini) ---
# Define o custo máximo mensal em dólares. Padrão: $5 (aproximadamente 50M tokens de saída)
MAX_GEMINI_COST=5

# --- Inteligência Artificial (Groq) - Opcional ---
# Alternativa gratuita e rápida. Obtenha em https://console.groq.com/
GROQ_API_KEY=sua-chave-api-do-groq-aqui

# --- Tokens do Instagram ---
# Adicione um ou mais tokens de acesso de usuário do Instagram, separados por vírgula.
# Estes tokens são usados para o login rápido sem OAuth.
IG_TOKENS=

# --- Configuração do Servidor ---
PORT=3000
NODE_ENV=production

# --- URL Pública do Deploy (Railway) ---
# Preencha com a URL gerada pelo Railway após o primeiro deploy.
# Exemplo: https://instagram-planner-production-1234.up.railway.app
BASE_URL=
