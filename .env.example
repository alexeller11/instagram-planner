# ── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=3000
# Gere com: openssl rand -base64 64
SESSION_SECRET=sua-chave-secreta-muito-longa-e-aleatoria-aqui
BASE_URL=http://localhost:3000
NODE_ENV=development

# ── INTELIGÊNCIA ARTIFICIAL ───────────────────────────────────────────────────
# Groq (principal — llama-3.3-70b-versatile)
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Google Gemini (secundário — gemini-2.5-flash)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# SambaNova Cloud (fallback de alta performance)
# Obtenha em: https://cloud.sambanova.ai
SAMBANOVA_API_KEY=...

# == BANCO DE DADOS ==
# MongoDB Atlas para persistência
# Configure em: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://...

# ── INSTAGRAM GRAPH API ───────────────────────────────────────────────────────
# Gere tokens de acesso de longa duração no Meta for Developers
# Separe múltiplos tokens por vírgula
IG_TOKENS=token_1,token_2
